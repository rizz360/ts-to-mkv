# If true, the original .ts file will be deleted after successful conversion
DELETE_TS=true

# Files (in GB) smaller or equal to this size will be remuxed, not re-encoded.
REMUX_SIZE_GB=3

# If the initial remux fails (often due to subtitle compatibility),
# setting this to true will try again without the subtitle tracks.
REMUX_FALLBACK_NO_SUBTITLES=true

# --- Encoding Settings ---
# Codec for video encoding. For Intel QSV: hevc_qsv. For NVIDIA: hevc_nvenc
VIDEO_CODEC=hevc_qsv

# Video bitrate for encoding. e.g., 2000k, 2500k, 4M
VIDEO_BITRATE=2500k

# QSV encoding preset (quality vs speed). Options:
# veryfast, faster, fast, medium, slow, slower, veryslow
VIDEO_PRESET=fast

# Codec for audio. 'copy' will stream copy without re-encoding.
AUDIO_CODEC=copy

# Ntfy endpoint
NTFY_URL=http://192.168.1.119:1888/ts-to-mkv